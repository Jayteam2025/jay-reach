# URL et clé publique (anon) de TON projet Supabase.
# Settings → API dans le dashboard Supabase.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique

# Optionnel — utilisé uniquement par `pnpm setup` (jamais commité).
# Token d'accès Supabase CLI : https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Référence du projet (l'id dans l'URL du dashboard).
SUPABASE_PROJECT_REF=

# Les clés des providers (LLM, FullEnrich, Bouncer, Smartlead...) ne se mettent
# PAS ici : elles se saisissent dans l'app (onglet Config), stockées chiffrées en DB.
